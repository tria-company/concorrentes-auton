# Copie para .env e preencha. NÃO commite o .env real.

# === LLM · Azure OpenAI (provider ativo se AZURE_OPENAI_ENDPOINT estiver definido) ===
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=<sua-chave>
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# AZURE_OPENAI_DEPLOYMENT_HEAVY=gpt-4.1

# === Fallback LLM (Anthropic via Model Router do Mastra) ===
# ANTHROPIC_API_KEY=<sua-chave>

# === Supabase ===
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-key>
SUPABASE_PUBLISHABLE_KEY=<publishable-key>
DATABASE_URL=postgresql://postgres.<ref>:<senha>@<host>.pooler.supabase.com:5432/postgres

# === Webhooks / orquestração ===
APIFY_WEBHOOK_SECRET=<segredo>
CRON_SECRET=<segredo>
INTERNAL_API_SECRET=<segredo>
